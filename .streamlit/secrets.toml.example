# Copy to .streamlit/secrets.toml for local Streamlit runs (do not commit secrets.toml).
# On Streamlit Community Cloud, paste the same keys in App Settings → Secrets.

GROQ_API_KEY = ""
GROQ_MODEL = "llama-3.3-70b-versatile"
GROQ_TIMEOUT_SECONDS = 30
GROQ_TEMPERATURE = 0.3
MAX_CANDIDATES_TO_LLM = 20
TOP_RECOMMENDATIONS = 5

HF_DATASET_ID = "ManikaSaini/zomato-restaurant-recommendation"
DATA_CACHE_PATH = "data/cache.parquet"
FORCE_REFRESH = false
