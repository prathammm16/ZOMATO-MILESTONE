# Hugging Face dataset (default matches problem statement)
HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation
# Optional — faster/more reliable HF downloads (https://huggingface.co/settings/tokens)
HF_TOKEN=
# Limit rows ingested from HF (Railway auto-defaults to 5000 if unset)
# HF_MAX_ROWS=5000
# Strip HF row metadata on Railway to save RAM (auto true on Railway)
# INGEST_STRIP_METADATA=true

# Cache normalized data locally (speeds up restarts)
DATA_CACHE_PATH=data/cache.parquet
FORCE_REFRESH=false

# Groq (Phase 3–4) — get a key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=30
GROQ_TEMPERATURE=0.3
MAX_CANDIDATES_TO_LLM=20
TOP_RECOMMENDATIONS=5
MAX_FIELD_CHARS=120

# Railway backend — set PYTHONPATH=. in Railway Variables
PYTHONPATH=.

# CORS for Vercel frontend (comma-separated origins, or * for all)
# CORS_ORIGINS=https://your-app.vercel.app

# Frontend (Vercel / local) — see frontend/.env.example
# VITE_API_BASE_URL=https://your-service.up.railway.app
